# APIs e Serviços
OPENAI_API_KEY=seu_openai_key_aqui
GROQ_API_KEY=seu_groq_key_aqui
GEMINI_API_KEY=seu_gemini_key_aqui

# Credenciais Morada
MORADA_LOGIN=seu_email_morada@example.com
MORADA_PASSWORD=sua_senha_morada_aqui

# Supabase (Opcional)
SUPABASE_URL=sua_url_supabase_aqui
SUPABASE_KEY=sua_chave_supabase_aqui

# Email
EMAIL_SENDER=seu_email@mouraleite.com.br
EMAIL_RECIPIENT=destinatario@mouraleite.com.br

# Configuração de Análise
PERIODO_ANALISE=24h

# Schedule
SCHEDULE_ENABLED=true
SCHEDULE_HOURS=09:00
SCHEDULE_DAYS=diario
SCHEDULE_FULL_PERIOD=24h
SCHEDULE_NOTIFY=dashboard
SCHEDULE_FREQUENCY=diario
SCHEDULE_PERIOD=2h

# Railway/Produção
PORT=8000
NODE_ENV=production
